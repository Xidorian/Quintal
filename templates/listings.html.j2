<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Quintal — Algarve rentals</title>
  <style>
    :root { --bg:#faf9f6; --card:#fff; --ink:#1f2421; --muted:#6b726e; --line:#e6e3dc;
            --green:#2e7d32; --grey:#8a8f8b; --red:#c62828; --accent:#3a6b52; }
    * { box-sizing:border-box; }
    body { margin:0; font:16px/1.5 system-ui,-apple-system,Segoe UI,Roboto,sans-serif;
           background:var(--bg); color:var(--ink); }
    header { padding:1.5rem 1.25rem 0.75rem; max-width:1100px; margin:0 auto; }
    h1 { margin:0 0 .25rem; font-size:1.5rem; }
    .caveat { background:#fff6e5; border:1px solid #f0d9a8; color:#7a5b12;
              padding:.6rem .8rem; border-radius:8px; font-size:.85rem; margin:.75rem 0; }
    .synthetic { background:#fdeaea; border-color:#e7b3b3; color:#8a2b2b; }
    .controls { display:flex; flex-wrap:wrap; gap:.75rem; align-items:end;
                max-width:1100px; margin:0 auto; padding:.5rem 1.25rem 1rem; }
    .controls label { display:flex; flex-direction:column; font-size:.75rem; color:var(--muted); gap:.2rem; }
    .controls input, .controls select { font-size:.9rem; padding:.35rem .5rem; border:1px solid var(--line);
                                        border-radius:6px; background:var(--card); }
    .sortbtns { display:flex; gap:.4rem; }
    .sortbtns button { font-size:.85rem; padding:.4rem .7rem; border:1px solid var(--line);
                       background:var(--card); border-radius:6px; cursor:pointer; }
    .sortbtns button[aria-pressed="true"] { background:var(--accent); color:#fff; border-color:var(--accent); }
    main { max-width:1100px; margin:0 auto; padding:0 1.25rem 3rem;
           display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:1rem; }
    .card { background:var(--card); border:1px solid var(--line); border-radius:12px; padding:1rem; }
    .row1 { display:flex; justify-content:space-between; gap:.5rem; align-items:baseline; }
    .price { font-size:1.35rem; font-weight:700; }
    .score { font-size:.8rem; color:#fff; background:var(--accent); padding:.15rem .5rem; border-radius:999px; }
    .title { font-size:.95rem; margin:.35rem 0 .1rem; }
    .loc { font-size:.8rem; color:var(--muted); }
    .band { display:inline-flex; align-items:center; gap:.3rem; font-size:.85rem; font-weight:600;
            padding:.25rem .55rem; border-radius:6px; margin:.6rem 0; border:1px solid var(--line); }
    .band.undervalued { color:var(--green); } .band.overpriced { color:var(--red); } .band.fair { color:var(--grey); }
    .conf { font-size:.7rem; color:var(--muted); font-weight:400; }
    .why { font-size:.78rem; color:var(--muted); margin:.2rem 0 .6rem; }
    .tags { display:flex; flex-wrap:wrap; gap:.3rem; }
    .tag { font-size:.72rem; padding:.15rem .45rem; border-radius:999px; background:#eef1ee; color:#3a463f; }
    .tag.warn { background:#fff2d6; color:#7a5b12; }
    .tag.no { background:#fdeaea; color:#8a2b2b; }
    .meta { font-size:.75rem; color:var(--muted); margin-top:.55rem; }
    a { color:var(--accent); }
    .empty { grid-column:1/-1; text-align:center; color:var(--muted); padding:2rem; }
  </style>
</head>
<body>
  <header>
    <h1>Quintal — Algarve rentals</h1>
    {% if synthetic %}
    <div class="caveat synthetic"><strong>Synthetic sample data.</strong> These {{ count }} listings
      are fabricated to prove the scoring/valuation pipeline — not real market data.</div>
    {% endif %}
    <div class="caveat">Valuation is <strong>relative to the current collected pool</strong>, not an
      official appraisal. Bands are shown with text as well as colour.</div>
  </header>

  <div class="controls">
    <div class="sortbtns" role="group" aria-label="Sort mode">
      <button data-sort="fit" aria-pressed="true">Best fit</button>
      <button data-sort="deal" aria-pressed="false">Best deal</button>
      <button data-sort="blend" aria-pressed="false">Fit + deal</button>
    </div>
    <label>Max price €<input id="fMaxPrice" type="number" min="0" step="50" placeholder="any"></label>
    <label>Min beds<input id="fMinBeds" type="number" min="0" step="1" placeholder="any"></label>
    <label>Yard only<select id="fYard"><option value="">no</option><option value="1">yes</option></select></label>
    <label>Band<select id="fBand"><option value="">any</option><option value="undervalued">🟢 undervalued</option>
      <option value="fair">⚪ fair</option><option value="overpriced">🔴 overpriced</option></select></label>
  </div>

  <main id="grid" aria-live="polite"></main>

  <script id="data" type="application/json">{{ listings_json | safe }}</script>
  <script>
    const DATA = JSON.parse(document.getElementById('data').textContent);
    const grid = document.getElementById('grid');
    let sortMode = 'fit';

    // Blend needs a pool-normalized "deal" score (more undervalued = better).
    const pcts = DATA.filter(d => d.valuation_pct !== null).map(d => d.valuation_pct);
    const minP = Math.min(...pcts, 0), maxP = Math.max(...pcts, 0);
    const dealNorm = d => d.valuation_pct === null ? 0
      : (maxP === minP ? 50 : 100 * (maxP - d.valuation_pct) / (maxP - minP));
    const blend = d => 0.5 * (d.match_score ?? 0) + 0.5 * dealNorm(d);

    const sorters = {
      fit:  (a,b) => (b.match_score ?? 0) - (a.match_score ?? 0),
      deal: (a,b) => dealNorm(b) - dealNorm(a),
      blend:(a,b) => blend(b) - blend(a),
    };

    function petTag(v){ if(v==='yes') return '<span class="tag">🐾 pets ok</span>';
      if(v==='no') return '<span class="tag no">🚫 no pets</span>';
      return '<span class="tag warn">🐾 pets unknown</span>'; }

    function card(d){
      const walk = d.walk_min !== null ? `${Math.round(d.walk_min)} min to beach` : 'beach walk unknown';
      const also = d.also_listed_at.length ? ` · also on ${d.also_listed_at.length} more` : '';
      const tags = [
        d.yard ? '<span class="tag">🌳 yard</span>' : (d.terrace ? '<span class="tag">🪴 terrace</span>' : ''),
        d.bathtub ? '<span class="tag">🛁 bathtub</span>' : '',
        d.furnished === true ? '<span class="tag">furnished</span>' : (d.furnished === false ? '<span class="tag">unfurnished</span>' : ''),
        petTag(d.pets),
      ].filter(Boolean).join('');
      const conf = d.confidence ? ` <span class="conf">(${d.confidence} confidence)</span>` : '';
      return `<article class="card">
        <div class="row1"><span class="price">€${d.price.toFixed(0)}/mo</span>
          <span class="score" title="preference match">fit ${d.match_score ?? '—'}/100</span></div>
        <p class="title">${d.title}</p>
        <p class="loc">${d.type} · ${d.beds ?? '?'} bed · ${d.baths ?? '?'} bath · ${d.size ?? '?'} m² · ${d.concelho}</p>
        <div class="band ${d.band}">${d.band_emoji} ${d.band_label}${d.valuation_pct !== null ? ` ${(d.valuation_pct*100).toFixed(0)>0?'+':''}${(d.valuation_pct*100).toFixed(0)}%` : ''}${conf}</div>
        <p class="why">${d.why.join(' · ')}</p>
        <div class="tags">${tags}</div>
        <p class="meta">${walk} · ${d.dist_town ? (d.dist_town/1000).toFixed(1)+' km from town' : ''} · ${d.source}${also}
          ${d.url ? ` · <a href="${d.url}" target="_blank" rel="noopener">listing ↗</a>` : ''}</p>
      </article>`;
    }

    function activeFilters(){
      const maxPrice = parseFloat(document.getElementById('fMaxPrice').value);
      const minBeds = parseInt(document.getElementById('fMinBeds').value);
      const yardOnly = document.getElementById('fYard').value === '1';
      const band = document.getElementById('fBand').value;
      return d =>
        (isNaN(maxPrice) || d.price <= maxPrice) &&
        (isNaN(minBeds) || (d.beds ?? 0) >= minBeds) &&
        (!yardOnly || d.yard) &&
        (!band || d.band === band);
    }

    function render(){
      const rows = DATA.filter(activeFilters()).sort(sorters[sortMode]);
      grid.innerHTML = rows.length ? rows.map(card).join('')
        : '<p class="empty">No listings match these filters.</p>';
    }

    document.querySelectorAll('.sortbtns button').forEach(b =>
      b.addEventListener('click', () => {
        sortMode = b.dataset.sort;
        document.querySelectorAll('.sortbtns button').forEach(x => x.setAttribute('aria-pressed', x === b));
        render();
      }));
    ['fMaxPrice','fMinBeds','fYard','fBand'].forEach(id =>
      document.getElementById(id).addEventListener('input', render));
    render();
  </script>
</body>
</html>
