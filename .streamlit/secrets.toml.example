# Copy to `.streamlit/secrets.toml` for local testing of the shared Gist store,
# or paste these two lines into the Streamlit Community Cloud app's Secrets box.
# The real `secrets.toml` is gitignored — never commit the token.

# A private GitHub Gist that holds preferences.json (the shared 👍/👎 store).
QUINTAL_GIST_ID = "your_gist_id_here"

# A fine-grained GitHub token with **Gists: read and write** and nothing else.
QUINTAL_GITHUB_TOKEN = "github_pat_xxx"
